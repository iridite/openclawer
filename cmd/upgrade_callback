#!/bin/bash

### This script is called after the user upgrades the application.

set -euo pipefail

APP_NAME="${TRIM_APPNAME:-oc-deploy}"

# 自动检测配置文件位置
if [ -d "/var/apps/${APP_NAME}/var/.openclaw" ]; then
    SRC_DIR="/var/apps/${APP_NAME}/var/.openclaw"
elif [ -d "/root/.openclaw" ]; then
    SRC_DIR="/root/.openclaw"
else
    SRC_DIR="${OC_HOME:-/root/.openclaw}"
fi

BACKUP_ROOT="${OC_DEPLOY_BACKUP_ROOT:-/root/oc-deploy}"
MARKER_FILE="${BACKUP_ROOT}/.upgrade_backup_path"
RESTORED_ITEMS=0

restore_entry() {
    local target="$1"
    local rel="$2"
    local item_type="$3"
    local backup_path="${BACKUP_DIR}/${rel}"

    if [ ! -e "${backup_path}" ]; then
        echo "[upgrade_callback] Skip missing backup path: ${backup_path}"
        return 0
    fi

    if [ "${item_type}" = "file" ]; then
        mkdir -p "$(dirname "${target}")"
        cp -a "${backup_path}" "${target}"
    else
        mkdir -p "${target}"
        cp -a "${backup_path}/." "${target}/"
    fi

    RESTORED_ITEMS=$((RESTORED_ITEMS + 1))
    echo "[upgrade_callback] Restored ${backup_path} -> ${target}"
}

if [ -f "${MARKER_FILE}" ]; then
    BACKUP_DIR="$(cat "${MARKER_FILE}")"
else
    BACKUP_DIR="$(ls -1dt "${BACKUP_ROOT}"/*-backup 2>/dev/null | head -n 1 || true)"
fi

if [ -z "${BACKUP_DIR}" ] || [ ! -d "${BACKUP_DIR}" ]; then
    echo "[upgrade_callback] Backup not found, skip restore."
    exit 0
fi

MANIFEST_FILE="${BACKUP_DIR}/manifest.tsv"
if [ -f "${MANIFEST_FILE}" ]; then
    while IFS='|' read -r target rel item_type; do
        [ -z "${target}" ] && continue
        case "${target}" in
            \#*) continue ;;
        esac
        restore_entry "${target}" "${rel}" "${item_type:-dir}"
    done < "${MANIFEST_FILE}"
else
    # Backward compatibility: restore legacy backup layout
    if [ -d "${BACKUP_DIR}/.openclaw" ]; then
        mkdir -p "${SRC_DIR}"
        cp -a "${BACKUP_DIR}/.openclaw/." "${SRC_DIR}/"
        RESTORED_ITEMS=$((RESTORED_ITEMS + 1))
        echo "[upgrade_callback] Restored legacy .openclaw from ${BACKUP_DIR}"
    fi
fi

if [ "${RESTORED_ITEMS}" -eq 0 ]; then
    echo "[upgrade_callback] No restorable items found in ${BACKUP_DIR}"
    exit 0
fi

rm -f "${MARKER_FILE}" || true
echo "[upgrade_callback] Restored from ${BACKUP_DIR} (items=${RESTORED_ITEMS})"
exit 0
