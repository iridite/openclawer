#!/bin/bash
# OpenClaw 卸载初始化脚本
# 在用户卸载应用前调用，用于清理配置文件和数据

# 日志文件路径
LOG_FILE="${TRIM_PKGVAR}/info.log"

# 记录日志消息
log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" | tee -a "${LOG_FILE}" 2>/dev/null || echo "$1"
}

log_msg "=========================================="
log_msg "OpenClaw 卸载清理开始"
log_msg "=========================================="

# 精准狙击运行 openclaw 的 node 进程，绝不误伤其他程序
pkill -f "openclaw/dist/index.js gateway"

# 强制杀死可能仍在运行的 OpenClaw 进程
pkill -9 -f "openclaw"

# 清理 root 用户的 OpenClaw 配置目录
if [ -d "/root/.openclaw" ]; then
    log_msg "正在删除 /root/.openclaw 配置目录..."
    rm -rf "/root/.openclaw"
    if [ $? -eq 0 ]; then
        log_msg "✅ /root/.openclaw 已删除"
    else
        log_msg "⚠️  删除 /root/.openclaw 失败"
    fi
else
    log_msg "ℹ️  /root/.openclaw 不存在，跳过"
fi

# 清理可能存在的其他用户配置（如果应用以其他用户运行）
if [ -n "${TRIM_APPNAME}" ] && [ -d "/home/${TRIM_APPNAME}/.openclaw" ]; then
    log_msg "正在删除 /home/${TRIM_APPNAME}/.openclaw 配置目录..."
    rm -rf "/home/${TRIM_APPNAME}/.openclaw"
    if [ $? -eq 0 ]; then
        log_msg "✅ /home/${TRIM_APPNAME}/.openclaw 已删除"
    else
        log_msg "⚠️  删除 /home/${TRIM_APPNAME}/.openclaw 失败"
    fi
fi

# 清理 appdir 配置（如果用户选择了 appdir 存储位置）
PKGVAR="/var/apps/${TRIM_APPNAME}/var"
if [ -d "${PKGVAR}/.openclaw" ]; then
    log_msg "正在删除 ${PKGVAR}/.openclaw 配置目录..."
    rm -rf "${PKGVAR}/.openclaw"
    if [ $? -eq 0 ]; then
        log_msg "✅ ${PKGVAR}/.openclaw 已删除"
    else
        log_msg "⚠️  删除 ${PKGVAR}/.openclaw 失败"
    fi
fi

