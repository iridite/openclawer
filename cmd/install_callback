#!/bin/bash
# OpenClaw 安装回调脚本
# 在用户安装应用后调用，用于初始化 openclaw.json 配置
#
# 根据用户的当前执行权限，会生成在 root 的家目录

# 日志文件路径
LOG_FILE="${TRIM_PKGVAR}/info.log"
PKGVAR="/var/apps/${TRIM_APPNAME}/var"
TARGET="/var/apps/${TRIM_APPNAME}/target"
# Node.js 可执行文件路径
NODE_PATH="/var/apps/nodejs_v22/target/bin/node"
NPM_PATH="/var/apps/nodejs_v22/target/bin/npm"

OPENCLAW_BIN="${PKGVAR}/node_modules/.bin/openclaw" # openclaw bin 路径


# 记录日志消息
# 参数: $1 - 要记录的消息内容
log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

# 锁定家目录和配置路径，确保所有子进程继承
export HOME="/root"
export OPENCLAW_CONFIG_PATH="/root/.openclaw/openclaw.json"
export PATH="/var/apps/nodejs_v22/target/bin:${PKGVAR}/node_modules/.bin:$PATH"

# 安装 openclaw 最新版本
# 在指定目录下安装 openclaw@latest
install_openclaw() {
    # 1. 确保环境变量和路径锁定
    local OPENCLAW_BIN="${PKGVAR}/node_modules/.bin/openclaw"

    log_msg "Installing openclaw@latest in ${PKGVAR}..."

    # 切换到应用目录并执行安装
    cd "${PKGVAR}" && npm install openclaw@latest >> ${LOG_FILE} 2>&1

    # 2. 替换测试逻辑：尝试执行二进制文件并获取版本号
    log_msg "Verifying openclaw binary execution..."

    # 验证步骤：
    # a. 检查二进制文件文件是否存在
    # b. 使用指定的 NODE_PATH 尝试运行该文件并获取版本信息
    if [ -f "$OPENCLAW_BIN" ] && node "$OPENCLAW_BIN" --version >> ${LOG_FILE} 2>&1; then # 双重变量，记得处理下
        log_msg "openclaw@latest installed and verified successfully"
        # 获取具体的版本号并记录到日志中（可选）
        local VERSION=$(node "$OPENCLAW_BIN" --version 2>/dev/null)
        log_msg "Detected version: $VERSION"
        return 0
    else
        # 验证失败的处理逻辑
        log_msg "Error: openclaw binary verification failed. Installation might be corrupted."
        echo "Failed to verify openclaw@latest installation." > "$TRIM_TEMP_LOGFILE"

        # 抓取最后 20 行日志辅助诊断
        tail -n 20 "${LOG_FILE}" >> "$TRIM_TEMP_LOGFILE"
        echo "Possible cause: Environment mismatch or incomplete dependencies." >> "$TRIM_TEMP_LOGFILE"
        echo "Please check the log above for details: ${LOG_FILE}" >> "$TRIM_TEMP_LOGFILE"
        exit 1
    fi
}

# 初始化 openclaw 配置
# 运行 openclaw setup 命令生成配置文件
setup_openclaw_config() {
    log_msg "Running openclaw setup to initialize configuration..."

    # 2. 执行基础初始化
    node ${OPENCLAW_BIN} setup >> ${LOG_FILE} 2>&1
    # 将配置写入到当前用户的目录中，并且确保它能被后续的 Node.js 脚本访问到

    if [ $? -eq 0 ]; then
        log_msg "openclaw setup executed successfully"
    else
        # 此时具体报错已经进入了 LOG_FILE 并且可能在控制台显示
        echo "Failed to execute openclaw setup. Full trace below:" > "${TRIM_TEMP_LOGFILE}"
        # 增加捕捉行数，因为 Node.js 的 Stack Trace（堆栈跟踪）通常比较长
        tail -n 50 "${LOG_FILE}" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi

    # ==========================================================
    # TODO 实现：向 openclaw.json 中写入 gateway.mode=local
    # ==========================================================
    log_msg "Injecting gateway.mode=local into configuration..."

    ${NODE_PATH} -e "
        const fs = require('fs');
        const filePath = '/root/.openclaw/openclaw.json';
        let config = {};

        // 1. 读取并解析现有的 JSON
        if (fs.existsSync(filePath)) {
            try {
                config = JSON.parse(fs.readFileSync(filePath, 'utf8'));
            } catch (e) {
                config = {};
            }
        }

        // 2. 确保 gateway 基础对象存在
        config.gateway = config.gateway || {};
        config.gateway.mode = 'local';
        config.gateway.host = '0.0.0.0';
        config.gateway.port = 18791;

        // 3. 【新增】实现模式 A：配置 CORS 允许所有来源
        config.gateway.controlUi = config.gateway.controlUi || {};
        config.gateway.controlUi.allowedOrigins = ['*'];

        // 4. 写回文件
        fs.writeFileSync(filePath, JSON.stringify(config, null, 2));
    " >> ${LOG_FILE} 2>&1

    if [ $? -eq 0 ]; then
        log_msg "openclaw configuration initialized and patched successfully"
        return 0
    else
        log_msg "Failed to patch openclaw configuration"
        echo "Failed to patch openclaw configuration" >> "${TRIM_TEMP_LOGFILE}"
        tail -n 20 "${LOG_FILE}" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi
}

setup_systemd_service() {
    log_msg "Setting up systemd service for OpenClaw..."

    node ${OPENCLAW_BIN} gateway install --force >> ${LOG_FILE} 2>&1

    if [ $? -eq 0 ]; then
        log_msg "Systemd service for OpenClaw installed successfully"
        return 0
    else
        log_msg "Failed to install systemd service for OpenClaw"
        echo "Failed to install systemd service for OpenClaw." > "${TRIM_TEMP_LOGFILE}"
        tail -n 20 "${LOG_FILE}" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi
}

generate_oc_token() {
    log_msg "Generating OpenClaw token..."

    node ${OPENCLAW_BIN} gateway start >> ${LOG_FILE} 2>&1

    if [ $? -eq 0 ]; then
        log_msg "OpenClaw token generated successfully"
        return 0
    else
        log_msg "Failed to generate OpenClaw token"
        echo "Failed to generate OpenClaw token." > "${TRIM_TEMP_LOGFILE}"
        tail -n 20 "${LOG_FILE}" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi

    sleep 2 # 等待服务启动，确保 token 生成逻辑有足够的时间执行
    # 实际上也不用关掉，就干脆这样一直保持 openclaw gateway 运行就行了

}

# entry point
# 步骤 2: 安装 openclaw
install_openclaw

# -----------------
# 执行配置初始化流程
log_msg "Starting OpenClaw configuration setup..."

# 运行 openclaw setup
setup_openclaw_config
setup_management_api_deps
setup_systemd_service
generate_oc_token

exit 0
