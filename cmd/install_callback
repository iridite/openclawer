#!/bin/bash
# OpenClaw 安装回调脚本
# 在用户安装应用后调用，用于初始化 openclaw.json 配置
#
# 根据用户的当前执行权限，会生成在 root 的家目录

# 日志文件路径
LOG_FILE="${TRIM_PKGVAR}/info.log"
PKGVAR="/var/apps/${TRIM_APPNAME}/var"
TARGET="/var/apps/${TRIM_APPNAME}/target"
# Node.js 可执行文件路径
NODE_PATH="/var/apps/nodejs_v22/target/bin/node"
NPM_PATH="/var/apps/nodejs_v22/target/bin/npm"

OPENCLAW_BIN="${PKGVAR}/node_modules/.bin/openclaw" # openclaw bin 路径


# 记录日志消息
# 参数: $1 - 要记录的消息内容
log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

# 锁定家目录和配置路径，确保所有子进程继承
export HOME="/root"
export OPENCLAW_CONFIG_PATH="/root/.openclaw/openclaw.json"
export PATH="/var/apps/nodejs_v22/target/bin:${PKGVAR}/node_modules/.bin:$PATH"

# 安装 openclaw 最新版本
# 在指定目录下安装 openclaw@latest
# 支持多镜像源切换和重试机制
install_openclaw() {
    # 1. 确保环境变量和路径锁定
    local OPENCLAW_BIN="${PKGVAR}/node_modules/.bin/openclaw"

    log_msg "Installing openclaw@latest in ${PKGVAR}..."

    # 定义多个镜像源（按优先级排序）
    local REGISTRIES=(
        "https://registry.npmmirror.com/"     # 淘宝镜像（国内最快）
        "https://registry.npm.taobao.org/"    # 淘宝镜像备用地址
        "https://registry.npmjs.org/"         # 官方源（国外）
    )

    # 每个镜像源的重试次数
    local MAX_RETRIES=2
    local INSTALL_SUCCESS=0

    # 遍历所有镜像源
    for REGISTRY in "${REGISTRIES[@]}"; do
        log_msg "Trying registry: ${REGISTRY}"

        # 对每个镜像源进行重试
        for attempt in $(seq 1 $MAX_RETRIES); do
            log_msg "Attempt ${attempt}/${MAX_RETRIES} with ${REGISTRY}..."

            # 清理可能的残留文件
            rm -rf "${PKGVAR}/node_modules/openclaw" 2>/dev/null
            rm -rf "${PKGVAR}/package-lock.json" 2>/dev/null

            # 执行安装，设置超时时间为 120 秒
            cd "${PKGVAR}" && timeout 120 npm install openclaw@latest \
                --registry="${REGISTRY}" \
                --no-audit \
                --no-fund \
                --prefer-online \
                --fetch-timeout=60000 \
                --fetch-retries=3 >> "${LOG_FILE}" 2>&1

            local INSTALL_EXIT_CODE=$?

            # 检查安装是否成功
            if [ $INSTALL_EXIT_CODE -eq 0 ]; then
                log_msg "npm install completed successfully with ${REGISTRY}"
                INSTALL_SUCCESS=1
                break 2  # 跳出两层循环
            else
                log_msg "npm install failed with exit code ${INSTALL_EXIT_CODE}"

                # 如果不是最后一次尝试，等待 3 秒后重试
                if [ $attempt -lt $MAX_RETRIES ]; then
                    log_msg "Waiting 1 seconds before retry..."
                    sleep 1
                fi
            fi
        done

        # 如果当前镜像源所有重试都失败，尝试下一个镜像源
        if [ $INSTALL_SUCCESS -eq 0 ]; then
            log_msg "All attempts failed with ${REGISTRY}, trying next registry..."
        fi
    done

    # 检查是否有任何镜像源安装成功
    if [ $INSTALL_SUCCESS -eq 0 ]; then
        log_msg "All registries failed for @latest, starting version fallback mechanism..."

        # 版本降级配置
        local MAX_VERSION_FALLBACK=5  # 最多降级 5 次
        local PRIMARY_REGISTRY="${REGISTRIES[0]}"  # 使用第一个镜像源进行降级

        # 获取可用的历史版本列表
        log_msg "Fetching available openclaw versions from ${PRIMARY_REGISTRY}..."

        # 使用 npm view 获取最近的稳定版本列表（排除 beta 版本）
        # OpenClaw 使用日期版本号格式：YYYY.M.D 或 YYYY.M.D-N
        local VERSIONS=$(cd "${PKGVAR}" && npm view openclaw versions --json --registry="${PRIMARY_REGISTRY}" 2>>"${LOG_FILE}" | \
            grep -oP '"\K[0-9]{4}\.[0-9]+\.[0-9]+(-[0-9]+)?(?=")' | \
            grep -v 'beta' | \
            tail -n 10 | \
            tac)

        if [ -z "$VERSIONS" ]; then
            log_msg "Failed to fetch version list, cannot proceed with fallback"
            echo "Failed to install openclaw from all registries and version list unavailable." > "$TRIM_TEMP_LOGFILE"
            echo "" >> "$TRIM_TEMP_LOGFILE"
            echo "Tried registries:" >> "$TRIM_TEMP_LOGFILE"
            for reg in "${REGISTRIES[@]}"; do
                echo "  - ${reg}" >> "$TRIM_TEMP_LOGFILE"
            done
            echo "" >> "$TRIM_TEMP_LOGFILE"
            echo "Last 30 lines of installation log:" >> "$TRIM_TEMP_LOGFILE"
            tail -n 30 "${LOG_FILE}" >> "$TRIM_TEMP_LOGFILE"
            exit 1
        else
            log_msg "Available versions for fallback: $(echo $VERSIONS | tr '\n' ' ')"

            local fallback_count=0
            local fallback_success=0

            # 遍历版本列表，尝试安装
            for VERSION in $VERSIONS; do
                # 检查是否超过最大降级次数
                if [ $fallback_count -ge $MAX_VERSION_FALLBACK ]; then
                    log_msg "Reached maximum fallback attempts (${MAX_VERSION_FALLBACK}), stopping..."
                    break
                fi

                fallback_count=$((fallback_count + 1))
                log_msg "Fallback attempt ${fallback_count}/${MAX_VERSION_FALLBACK}: trying openclaw@${VERSION}..."

                # 清理残留文件
                rm -rf "${PKGVAR}/node_modules/openclaw" 2>/dev/null
                rm -rf "${PKGVAR}/package-lock.json" 2>/dev/null

                # 尝试安装指定版本
                cd "${PKGVAR}" && timeout 120 npm install openclaw@${VERSION} \
                    --registry="${PRIMARY_REGISTRY}" \
                    --no-audit \
                    --no-fund \
                    --prefer-online \
                    --fetch-timeout=60000 \
                    --fetch-retries=3 >> "${LOG_FILE}" 2>&1

                local FALLBACK_EXIT_CODE=$?

                if [ $FALLBACK_EXIT_CODE -eq 0 ]; then
                    log_msg "Successfully installed openclaw@${VERSION} via fallback"
                    fallback_success=1
                    INSTALL_SUCCESS=1
                    break
                else
                    log_msg "Failed to install openclaw@${VERSION}, trying older version..."
                    sleep 2
                fi
            done

            if [ $fallback_success -eq 0 ]; then
                log_msg "All fallback versions failed"
                echo "Failed to install openclaw from all available methods." > "$TRIM_TEMP_LOGFILE"
                echo "" >> "$TRIM_TEMP_LOGFILE"
                echo "Tried methods:" >> "$TRIM_TEMP_LOGFILE"
                echo "  1. Latest version from all registries:" >> "$TRIM_TEMP_LOGFILE"
                for reg in "${REGISTRIES[@]}"; do
                    echo "     - ${reg}" >> "$TRIM_TEMP_LOGFILE"
                done
                echo "  2. Version fallback (up to ${MAX_VERSION_FALLBACK} older versions)" >> "$TRIM_TEMP_LOGFILE"
                echo "     Tried versions: $(echo "$VERSIONS" | head -n $MAX_VERSION_FALLBACK | tr '\n' ' ')" >> "$TRIM_TEMP_LOGFILE"
                echo "" >> "$TRIM_TEMP_LOGFILE"
                echo "Last 40 lines of installation log:" >> "$TRIM_TEMP_LOGFILE"
                tail -n 40 "${LOG_FILE}" >> "$TRIM_TEMP_LOGFILE"
                echo "" >> "$TRIM_TEMP_LOGFILE"
                echo "Possible solutions:" >> "$TRIM_TEMP_LOGFILE"
                echo "  - Check network connectivity" >> "$TRIM_TEMP_LOGFILE"
                echo "  - Verify DNS resolution" >> "$TRIM_TEMP_LOGFILE"
                echo "  - Check if npm registry is accessible" >> "$TRIM_TEMP_LOGFILE"
                echo "  - Try manual installation: cd ${PKGVAR} && npm install openclaw" >> "$TRIM_TEMP_LOGFILE"
                exit 1
            fi
        fi
    fi

    # 2. 验证安装：尝试执行二进制文件并获取版本号
    log_msg "Verifying openclaw binary execution..."

    # 验证步骤：
    # a. 检查二进制文件是否存在
    # b. 使用指定的 NODE_PATH 尝试运行该文件并获取版本信息
    if [ -f "$OPENCLAW_BIN" ] && node "$OPENCLAW_BIN" --version >> ${LOG_FILE} 2>&1; then
        log_msg "openclaw@latest installed and verified successfully"
        # 获取具体的版本号并记录到日志中
        local VERSION=$(node "$OPENCLAW_BIN" --version 2>/dev/null)
        log_msg "Detected version: $VERSION"
        return 0
    else
        # 验证失败的处理逻辑
        log_msg "Error: openclaw binary verification failed. Installation might be corrupted."
        echo "Failed to verify openclaw@latest installation." > "$TRIM_TEMP_LOGFILE"
        echo "" >> "$TRIM_TEMP_LOGFILE"
        echo "Binary path: ${OPENCLAW_BIN}" >> "$TRIM_TEMP_LOGFILE"
        echo "Binary exists: $([ -f "$OPENCLAW_BIN" ] && echo 'Yes' || echo 'No')" >> "$TRIM_TEMP_LOGFILE"
        echo "" >> "$TRIM_TEMP_LOGFILE"
        echo "Last 20 lines of log:" >> "$TRIM_TEMP_LOGFILE"
        tail -n 20 "${LOG_FILE}" >> "$TRIM_TEMP_LOGFILE"
        echo "" >> "$TRIM_TEMP_LOGFILE"
        echo "Possible causes:" >> "$TRIM_TEMP_LOGFILE"
        echo "  - Incomplete installation" >> "$TRIM_TEMP_LOGFILE"
        echo "  - Node.js version mismatch" >> "$TRIM_TEMP_LOGFILE"
        echo "  - Missing dependencies" >> "$TRIM_TEMP_LOGFILE"
        echo "" >> "$TRIM_TEMP_LOGFILE"
        echo "Full log: ${LOG_FILE}" >> "$TRIM_TEMP_LOGFILE"
        exit 1
    fi
}

# 初始化 openclaw 配置
# 运行 openclaw setup 命令生成配置文件
setup_openclaw_config() {
    log_msg "Running openclaw setup to initialize configuration..."

    # 2. 执行基础初始化
    node ${OPENCLAW_BIN} setup >> ${LOG_FILE} 2>&1
    # 将配置写入到当前用户的目录中，并且确保它能被后续的 Node.js 脚本访问到

    if [ $? -eq 0 ]; then
        log_msg "openclaw setup executed successfully"
    else
        # 此时具体报错已经进入了 LOG_FILE 并且可能在控制台显示
        echo "Failed to execute openclaw setup. Full trace below:" > "${TRIM_TEMP_LOGFILE}"
        # 增加捕捉行数，因为 Node.js 的 Stack Trace（堆栈跟踪）通常比较长
        tail -n 50 "${LOG_FILE}" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi

    # ==========================================================
    # TODO 实现：向 openclaw.json 中写入 gateway.mode=local
    # ==========================================================
    log_msg "Injecting gateway.mode=local into configuration..."

    ${NODE_PATH} -e "
        const fs = require('fs');
        const filePath = '/root/.openclaw/openclaw.json';
        let config = {};

        // 1. 读取并解析现有的 JSON
        if (fs.existsSync(filePath)) {
            try {
                config = JSON.parse(fs.readFileSync(filePath, 'utf8'));
            } catch (e) {
                config = {};
            }
        }

        // 2. 确保 gateway 基础对象存在
        config.gateway = config.gateway || {};
        config.gateway.mode = 'local';
        config.gateway.port = 18789;
        config.gateway.bind = 'lan';
        config.gateway.trustedProxies = ['10.0.0.1', '127.0.0.1', '::1'];

        // 3. 配置认证模式为 token
        config.gateway.auth = config.gateway.auth || {};
        config.gateway.auth.mode = 'token';

        // 4. 配置 Control UI - 允许所有来源并禁用设备授权
        config.gateway.controlUi = config.gateway.controlUi || {};
        config.gateway.controlUi.allowedOrigins = ['*'];
        config.gateway.controlUi.allowInsecureAuth = true;
        config.gateway.controlUi.dangerouslyDisableDeviceAuth = true;
        config.gateway.controlUi.dangerouslyAllowHostHeaderOriginFallback = true;

        // 5. 配置 reload hybrid 模式
        config.gateway.reload = config.gateway.reload || {};
        config.gateway.reload.mode = 'hybrid';
        config.gateway.reload.debounceMs = 300;

        // 6. 写回文件
        fs.writeFileSync(filePath, JSON.stringify(config, null, 2));
    " >> ${LOG_FILE} 2>&1

    if [ $? -eq 0 ]; then
        log_msg "openclaw configuration initialized and patched successfully"
        return 0
    else
        log_msg "Failed to patch openclaw configuration"
        echo "Failed to patch openclaw configuration" >> "${TRIM_TEMP_LOGFILE}"
        tail -n 20 "${LOG_FILE}" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi
}

generate_oc_token() {
    log_msg "Starting OpenClaw gateway via nohup to generate token..."

    # 1. 定义真实的 JS 入口路径（绕过 .bin 软链接，防止环境问题）
    local OC_JS_PATH="${PKGVAR}/node_modules/openclaw/dist/index.js"

    # 2. 杀掉可能残留的旧进程，确保端口清空
    pkill -f "openclaw/dist/index.js gateway" 2>/dev/null
    sleep 1

    # 3. 使用 nohup 在后台启动，强行绑定 18791 端口，日志追加到 LOG_FILE
    nohup env HOME="/root" OPENCLAW_CONFIG_PATH="/root/.openclaw/openclaw.json" \
    ${NODE_PATH} ${OC_JS_PATH} gateway --port 18789 >> "${LOG_FILE}" 2>&1 &

    # 4. 抓取刚才放入后台的进程 PID
    local GW_PID=$!
    log_msg "Gateway started in background with PID: $GW_PID"

    # 5. 等待 5 秒，给网关充足的时间去初始化、绑定端口和写入 token 文件
    log_msg "Waiting 5 seconds for initialization and token generation..."
    sleep 5

    # 6. 检查该 PID 是否依然存活 (kill -0 只是探测，不会真的杀进程)
    if kill -0 $GW_PID 2>/dev/null; then
        log_msg "OpenClaw token generated and gateway is running stably"
        return 0
    else
        # 如果 PID 没了，说明启动瞬间就崩溃了
        log_msg "Failed to start OpenClaw gateway or generate token"
        echo "Failed to start OpenClaw gateway. Process crashed shortly after startup." > "${TRIM_TEMP_LOGFILE}"

        # 抓取最后的日志找出死因
        tail -n 30 "${LOG_FILE}" >> "${TRIM_TEMP_LOGFILE}"
        exit 1
    fi
}

# entry point
# 步骤 2: 安装 openclaw
install_openclaw

# -----------------
# 执行配置初始化流程
log_msg "Starting OpenClaw configuration setup..."

# 运行 openclaw setup
setup_openclaw_config
generate_oc_token

exit 0
