#!/bin/bash
# OpenClaw 应用管理脚本
# 用于启动、停止和检查应用状态

# 日志文件路径
LOG_FILE="${TRIM_PKGVAR}/info.log"
# 进程 PID 文件路径
PID_FILE="${TRIM_PKGVAR}/app.pid"

# Binaries
BASE_DIR="/var/apps/${TRIM_APPNAME}"
## Node.js 可执行文件路径
NODE_PATH="/var/apps/nodejs_v22/target/bin/node"
## npm 可执行文件路径
NPM_PATH="/var/apps/nodejs_v22/target/bin/npm"

# HTML pages
MANAGEMENT_API="${BASE_DIR}/target/server/management-api.js"
IFRAME_PROXY="${BASE_DIR}/target/server/iframe-proxy.js"
#-----------------
GATEWAY_PORT="18789"
PROXY_PORT="18791"
MANAGEMENT_PORT="18790"
# ----------------

# ----------------------------------------------------------------
# 主程序设计
# 整体设计如下：
# manager 作为前端 dashboard，需要跟随 fnos 生命周期活动
# proxy 同上，提供可能需要的反向代理，使得网页能够正常显示
# OpenClaw Gateway 以 pm2 方式运行，不使用 PID 方式进行管控
# ----------------------------------------------------------------

# 记录日志消息
# 参数: $1 - 要记录的消息内容
log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

# 启动应用进程
# 如果进程已经在运行，则直接返回
# 否则在后台启动进程并将 PID 写入文件
start_process() {
    log_msg "========================================="
    log_msg "开始启动服务..."
    log_msg "========================================="

    # 启动前强制清理可能残留的进程
    log_msg "清理可能残留的进程..."
    pkill -9 -f "management-api.js" 2>/dev/null && log_msg "清理了残留的 management-api.js" || true
    pkill -9 -f "iframe-proxy.js" 2>/dev/null && log_msg "清理了残留的 iframe-proxy.js" || true
    lsof -ti:${MANAGEMENT_PORT} 2>/dev/null | xargs kill -9 2>/dev/null && log_msg "清理了端口 ${MANAGEMENT_PORT}" || true
    lsof -ti:${PROXY_PORT} 2>/dev/null | xargs kill -9 2>/dev/null && log_msg "清理了端口 ${PROXY_PORT}" || true
    sleep 1
    log_msg "清理完成"

    # 检查进程是否已经在运行
    if status; then
        log_msg "⚠️  服务已经在运行，无需重复启动"
        return 0
    fi

    log_msg "[1/3] 检查依赖和文件..."

    log_msg "[1/3] 检查依赖和文件..."

    # 检查端口是否被占用
    if ss -ltn 2>/dev/null | grep -q ":${MANAGEMENT_PORT}\s"; then
        log_msg "⚠️  端口 ${MANAGEMENT_PORT} 已被占用，尝试清理..."

        # 找到占用端口的进程
        local port_pid=$(lsof -ti:${MANAGEMENT_PORT} 2>/dev/null | head -1)
        if [ -n "${port_pid}" ]; then
            log_msg "杀掉占用端口的进程 PID: ${port_pid}"
            kill -9 "${port_pid}" 2>/dev/null || true
            sleep 1
        fi

        # 再次检查
        if ss -ltn 2>/dev/null | grep -q ":${MANAGEMENT_PORT}\s"; then
            log_msg "❌ 端口 ${MANAGEMENT_PORT} 仍被占用，无法启动"
            echo "Port ${MANAGEMENT_PORT} is in use" > "${TRIM_TEMP_LOGFILE}"
            return 1
        fi
    fi


    # 检查 Node.js
    if [ ! -x "${NODE_PATH}" ]; then
        log_msg "❌ Node.js 未找到: ${NODE_PATH}"
        echo "Node.js not found" > "${TRIM_TEMP_LOGFILE}"
        return 1
    fi
    log_msg "✅ Node.js 路径: ${NODE_PATH}"

    # 检查 Management API
    if [ ! -f "${MANAGEMENT_API}" ]; then
        log_msg "❌ Management API 未找到: ${MANAGEMENT_API}"
        echo "Management API not found" > "${TRIM_TEMP_LOGFILE}"
        return 1
    fi
    log_msg "✅ Management API 路径: ${MANAGEMENT_API}"

    # 检查 iframe-proxy
    if [ ! -f "${IFRAME_PROXY}" ]; then
        log_msg "⚠️  iframe-proxy 未找到: ${IFRAME_PROXY}"
        log_msg "⚠️  将仅启动 Management API，Dashboard 嵌入功能将不可用"
        # 不返回错误，继续启动 Management API
    else
        log_msg "✅ iframe-proxy 路径: ${IFRAME_PROXY}"
    fi


    log_msg "[2/3] 启动服务进程..."

    # 启动 Management API
    log_msg "启动 Management API (端口: ${MANAGEMENT_PORT})..."
    (
        export TRIM_PKGVAR="${TRIM_PKGVAR}"
        export TRIM_APPDEST="${TRIM_APPDEST}"
        export MANAGEMENT_PORT="${MANAGEMENT_PORT}"
        export GATEWAY_PORT="${GATEWAY_PORT}"

        exec "${NODE_PATH}" "${MANAGEMENT_API}"
    ) >> ${LOG_FILE} 2>&1 &

    local main_pid=$!
    # 将后台进程的 PID 写入 PID 文件
    printf "%s" "${main_pid}" > ${PID_FILE}
    log_msg "✅ Management API 已启动，PID: ${main_pid}"

    # 启动 iframe-proxy（用于嵌入 OpenClaw Dashboard）
    local proxy_pid_file="${TRIM_PKGVAR}/proxy.pid"
    if [ -f "${IFRAME_PROXY}" ]; then
        log_msg "启动 iframe-proxy (端口: ${PROXY_PORT})..."
        (
            export GATEWAY_PORT="${GATEWAY_PORT}"
            export PROXY_PORT="${PROXY_PORT}"
            export BIND_ADDR="127.0.0.1"
            export TOKEN_FILE="${TRIM_PKGVAR}/.gateway_token"

            # 从 openclaw.json 读取 token 并写入临时文件
            if [ -f "/root/.openclaw/openclaw.json" ]; then
                "${NODE_PATH}" -e "
                    try {
                        const fs = require('fs');
                        const config = JSON.parse(fs.readFileSync('/root/.openclaw/openclaw.json', 'utf8'));
                        const token = config?.gateway?.auth?.token || '';
                        if (token) {
                            fs.writeFileSync('${TRIM_PKGVAR}/.gateway_token', token);
                            console.log('[启动] 已从 openclaw.json 读取 token');
                        } else {
                            console.log('[启动] 警告: openclaw.json 中未找到 token');
                        }
                    } catch(e) {
                        console.log('[启动] 错误: 无法读取 token -', e.message);
                    }
                " >> ${LOG_FILE} 2>&1
            else
                log_msg "⚠️  未找到 /root/.openclaw/openclaw.json，iframe-proxy 将无法自动注入 token"
            fi

            exec "${NODE_PATH}" "${IFRAME_PROXY}"
        ) >> ${LOG_FILE} 2>&1 &

        local proxy_pid=$!
        printf "%s" "${proxy_pid}" > ${proxy_pid_file}
        log_msg "✅ iframe-proxy 已启动，PID: ${proxy_pid}"
    else
        log_msg "⚠️  跳过 iframe-proxy 启动（文件不存在）"
    fi

    log_msg "[3/3] 等待服务就绪..."

    log_msg "[3/3] 等待服务就绪..."

    # 等待端口就绪（而不是检查进程）
    log_msg "等待 Management API 端口 ${MANAGEMENT_PORT} 就绪..."
    local ready=0
    for i in $(seq 1 10); do
        sleep 1
        if ss -ltn 2>/dev/null | grep -q ":${MANAGEMENT_PORT}\s"; then
            ready=1
            log_msg "✅ Management API 端口 ${MANAGEMENT_PORT} 已就绪"
            break
        fi
        log_msg "等待 Management API 中... (${i}/10)"
    done

    if [ $ready -eq 0 ]; then
        log_msg "⚠️  Management API 端口未就绪，检查进程状态..."

        # 检查进程是否还活着
        if ! check_process "${main_pid}"; then
            log_msg "❌ Management API 进程已退出，启动失败"
            log_msg "最近 20 行日志："
            tail -20 "${LOG_FILE}"
            rm -f "${PID_FILE}"
            return 1
        fi

        log_msg "⚠️  Management API 进程正在运行但端口未就绪，可能需要更多时间"
    fi

    # 等待 iframe-proxy 端口就绪
    if [ -f "${IFRAME_PROXY}" ]; then
        log_msg "等待 iframe-proxy 端口 ${PROXY_PORT} 就绪..."
        local proxy_ready=0
        for i in $(seq 1 10); do
            sleep 1
            if ss -ltn 2>/dev/null | grep -q ":${PROXY_PORT}\s"; then
                proxy_ready=1
                log_msg "✅ iframe-proxy 端口 ${PROXY_PORT} 已就绪"
                break
            fi
            log_msg "等待 iframe-proxy 中... (${i}/10)"
        done

        if [ $proxy_ready -eq 0 ]; then
            log_msg "⚠️  iframe-proxy 端口 ${PROXY_PORT} 未就绪，检查进程状态..."

            # 检查进程是否还活着
            if ! check_process "${proxy_pid}"; then
                log_msg "❌ iframe-proxy 进程已退出，启动失败"
                log_msg "❌ Dashboard 嵌入功能将不可用，但 Management API 仍在运行"
                log_msg "最近 20 行日志："
                tail -20 "${LOG_FILE}"
                rm -f "${proxy_pid_file}"
            else
                log_msg "⚠️  iframe-proxy 进程正在运行但端口未就绪，可能需要更多时间"
            fi
        fi
    fi

    log_msg "========================================="
    log_msg "服务启动完成"
    log_msg "Management API: http://127.0.0.1:${MANAGEMENT_PORT}"
    if [ -f "${IFRAME_PROXY}" ]; then
        log_msg "iframe-proxy: http://127.0.0.1:${PROXY_PORT}"
    fi
    log_msg "========================================="

    # # 等待 3 秒后检查进程是否存活
    # sleep 3
    # if ! check_process "${PID_FILE}"; then
    #     log_msg "❌ 进程启动失败"
    #     echo "Process failed to start, see log for details" > "${TRIM_TEMP_LOGFILE}"
    #     tail -10 "${LOG_FILE}" >> "${TRIM_TEMP_LOGFILE}"
    #     rm -f "${PID_FILE}"
    #     return 1
    # fi

    return 0
}

# 停止应用进程
# 先尝试发送 TERM 信号优雅关闭，等待最多 10 秒
# 如果进程仍未退出，则发送 KILL 信号强制终止
stop_process() {
    log_msg "========================================="
    log_msg "开始停止服务..."
    log_msg "========================================="

    # 停止 Management API
    log_msg "[1/2] 停止 Management API..."
    # 检查 PID 文件是否存在且可读
    if [ -r "${PID_FILE}" ]; then
        # 读取 PID 并去除空白字符
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')

        log_msg "Management API PID: ${pid}"
        # 检查进程是否存在
        if ! check_process "${pid}"; then
            # 进程不存在，删除 PID 文件
            rm -f "${PID_FILE}"
            log_msg "Management API 进程不存在，删除 PID 文件"
        else
            # 发送 TERM 信号尝试优雅关闭
            log_msg "发送 TERM 信号到 Management API (PID:${pid})..."
            kill -TERM ${pid} >> ${LOG_FILE} 2>&1

            # 等待进程退出，最多等待 3 秒
            local count=0
            while check_process "${pid}" && [ $count -lt 3 ]; do
                sleep 1
                count=$((count + 1))
                log_msg "等待 Management API 退出... (${count}s/3s)"
            done

            # 如果进程仍在运行，发送 KILL 信号强制终止
            if check_process "${pid}"; then
                log_msg "发送 KILL 信号到 Management API (PID:${pid})..."
                kill -KILL "${pid}"
                sleep 1
                rm -f "${PID_FILE}"
                log_msg "✅ Management API 已强制停止"
            else
                log_msg "✅ Management API 已优雅停止"
            fi
        fi
    else
        log_msg "Management API PID 文件不存在，跳过"
    fi

    # 停止 iframe-proxy
    log_msg "[2/2] 停止 iframe-proxy..."
    local proxy_pid_file="${TRIM_PKGVAR}/proxy.pid"
    if [ -r "${proxy_pid_file}" ]; then
        local proxy_pid=$(head -n 1 "${proxy_pid_file}" | tr -d '[:space:]')
        log_msg "iframe-proxy PID: ${proxy_pid}"

        if check_process "${proxy_pid}"; then
            log_msg "发送 TERM 信号到 iframe-proxy (PID:${proxy_pid})..."
            kill -TERM "${proxy_pid}" 2>/dev/null

            # 等待进程退出，最多等待 3 秒
            local count=0
            while check_process "${proxy_pid}" && [ $count -lt 3 ]; do
                sleep 1
                count=$((count + 1))
                log_msg "等待 iframe-proxy 退出... (${count}s/3s)"
            done

            # 如果进程仍在运行，发送 KILL 信号强制��止
            if check_process "${proxy_pid}"; then
                log_msg "发送 KILL 信号到 iframe-proxy (PID:${proxy_pid})..."
                kill -KILL "${proxy_pid}" 2>/dev/null
                log_msg "✅ iframe-proxy 已强制停止"
            else
                log_msg "✅ iframe-proxy 已优雅停止"
            fi
        else
            log_msg "iframe-proxy 进程不存在"
        fi
        rm -f "${proxy_pid_file}"
    else
        log_msg "iframe-proxy PID 文件不存在，跳过"
    fi

    # 兜底清理
    log_msg "执行兜底清理..."
    pkill -f "management-api.js" 2>/dev/null && log_msg "清理残留的 management-api.js 进程" || true
    pkill -f "node.*${MANAGEMENT_API}" 2>/dev/null && log_msg "清理残留的 Management API 进程" || true
    pkill -f "iframe-proxy.js" 2>/dev/null && log_msg "清理残留的 iframe-proxy.js 进程" || true
    pkill -f "node.*${IFRAME_PROXY}" 2>/dev/null && log_msg "清理残留的 iframe-proxy 进程" || true

    # 强制清理端口占用
    log_msg "检查端口占用..."
    local port_pids=$(lsof -ti:${MANAGEMENT_PORT} 2>/dev/null)
    if [ -n "${port_pids}" ]; then
        log_msg "发现端口 ${MANAGEMENT_PORT} 被占用，强制清理 PID: ${port_pids}"
        echo "${port_pids}" | xargs kill -9 2>/dev/null || true
    else
        log_msg "端口 ${MANAGEMENT_PORT} 未被占用"
    fi

    local proxy_port_pids=$(lsof -ti:${PROXY_PORT} 2>/dev/null)
    if [ -n "${proxy_port_pids}" ]; then
        log_msg "发现端口 ${PROXY_PORT} 被占用，强制清理 PID: ${proxy_port_pids}"
        echo "${proxy_port_pids}" | xargs kill -9 2>/dev/null || true
    else
        log_msg "端口 ${PROXY_PORT} 未被占用"
    fi

    log_msg "========================================="
    log_msg "服务停止完成"
    log_msg "========================================="

    return 0
}

# 检查进程是否在运行
check_process() {
    local pid=$1
    if [ -z "${pid}" ]; then
        return 1
    fi
    if ps -p "${pid}" > /dev/null 2>&1; then
        return 0
    else
        return 1
    fi
}

# 检查应用状态
# 返回: 0 表示应用正在运行，3 表示应用未运行，1 表示出错

status() {
    local main_running=0
    local proxy_running=0

    # 检查 Management API
    if [ -f "${PID_FILE}" ]; then
        local pid
        pid=$(cat "${PID_FILE}" 2>/dev/null)
        if check_process "${pid}"; then
            log_msg "CHECKING: Management API 正在运行 (PID: ${pid})"
            main_running=1
        else
            log_msg "CHECKING: ERR Management API 进程已停止，但 PID 文件存在 (PID: ${pid})"
            rm -f "${PID_FILE}"
        fi
    else
        log_msg "CHECKING: Management API 未运行"
    fi

    # 检查 iframe-proxy
    local proxy_pid_file="${TRIM_PKGVAR}/proxy.pid"
    if [ -f "${proxy_pid_file}" ]; then
        local proxy_pid
        proxy_pid=$(cat "${proxy_pid_file}" 2>/dev/null)
        if check_process "${proxy_pid}"; then
            log_msg "CHECKING: iframe-proxy 正在运行 (PID: ${proxy_pid})"
            proxy_running=1
        else
            log_msg "CHECKING: ERR iframe-proxy 进程已停止，但 PID 文件存在 (PID: ${proxy_pid})"
            rm -f "${proxy_pid_file}"
        fi
    else
        log_msg "CHECKING: iframe-proxy 未运行"
    fi

    # 只要 Management API 在运行就返回 0（iframe-proxy 是辅助服务）
    if [ $main_running -eq 1 ]; then
        return 0
    else
        return 3
    fi
}

# 命令行参数处理
# 支持的命令: start, stop, status
case $1 in
start)
    # 启动命令：启动应用进程
    # 成功返回 0，失败返回 1
    start_process
    ;;
stop)
    # 停止命令：停止正在运行的应用
    # 成功返回 0，失败返回 1
    stop_process
    ;;
status)
    # 状态检查命令：检查应用是否正在运行
    # 运行中返回 0，未运行返回 3
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
restart)
    echo "Restarting process ..."
    stop_process
    sleep 2
    start_process
    ;;
*)
    # 未知命令，返回错误
    echo "使用方法: $0 {start|stop|restart|status}"
    exit 1
    ;;
esac
