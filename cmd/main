#!/bin/bash
# OpenClaw 应用管理脚本
# 用于启动、停止和检查应用状态

# 日志文件路径
LOG_FILE="${TRIM_PKGVAR}/info.log"
# 进程 PID 文件路径
PID_FILE="${TRIM_PKGVAR}/app.pid"

# Binaries
BASE_DIR="/var/apps/${TRIM_APPNAME}"
## Node.js 可执行文件路径
NODE_PATH="/var/apps/nodejs_v22/target/bin/node"
## npm 可执行文件路径
NPM_PATH="/var/apps/nodejs_v22/target/bin/npm"

# HTML pages
MANAGEMENT_API="${BASE_DIR}/target/server/management-api.js"
#-----------------
GATEWAY_PORT="18789"
PROXY_PORT="18790"
MANAGEMENT_PORT="18790"
# ----------------

# ----------------------------------------------------------------
# 主程序设计
# 整体设计如下：
# manager 作为前端 dashboard，需要跟随 fnos 生命周期活动
# proxy 同上，提供可能需要的反向代理，使得网页能够正常显示
# OpenClaw Gateway 以 pm2 方式运行，不使用 PID 方式进行管控
# ----------------------------------------------------------------

# 记录日志消息
# 参数: $1 - 要记录的消息内容
log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

# 启动应用进程
# 如果进程已经在运行，则直接返回
# 否则在后台启动进程并将 PID 写入文件
start_process() {
    # 启动前强制清理可能残留的进程
    log_msg "清理可能残留的进程..."
    pkill -9 -f "management-api.js" 2>/dev/null || true
    lsof -ti:${MANAGEMENT_PORT} 2>/dev/null | xargs kill -9 2>/dev/null || true
    sleep 1

    # 检查进程是否已经在运行
    if status; then
        log_msg "${APP_NAME} is already running"
        return 0
    fi

    # 检查端口是否被占用
    if ss -ltn 2>/dev/null | grep -q ":${MANAGEMENT_PORT}\s"; then
        log_msg "⚠️  端口 ${MANAGEMENT_PORT} 已被占用，尝试清理..."

        # 找到占用端口的进程
        local port_pid=$(lsof -ti:${MANAGEMENT_PORT} 2>/dev/null | head -1)
        if [ -n "${port_pid}" ]; then
            log_msg "杀掉占用端口的进程 PID: ${port_pid}"
            kill -9 "${port_pid}" 2>/dev/null || true
            sleep 1
        fi

        # 再次检查
        if ss -ltn 2>/dev/null | grep -q ":${MANAGEMENT_PORT}\s"; then
            log_msg "❌ 端口 ${MANAGEMENT_PORT} 仍被占用，无法启动"
            echo "Port ${MANAGEMENT_PORT} is in use" > "${TRIM_TEMP_LOGFILE}"
            return 1
        fi
    fi


    # 检查 Node.js
    if [ ! -x "${NODE_PATH}" ]; then
        log_msg "❌ Node.js 未找到: ${NODE_PATH}"
        echo "Node.js not found" > "${TRIM_TEMP_LOGFILE}"
        return 1
    fi

    # 检查 Management API
    if [ ! -f "${MANAGEMENT_API}" ]; then
        log_msg "❌ Management API 未找到: ${MANAGEMENT_API}"
        echo "Management API not found" > "${TRIM_TEMP_LOGFILE}"
        return 1
    fi


    log_msg "Starting process now..."

    (
        export TRIM_PKGVAR="${TRIM_PKGVAR}"
        export TRIM_APPDEST="${TRIM_APPDEST}"
        export MANAGEMENT_PORT="${MANAGEMENT_PORT}"
        export GATEWAY_PORT="${GATEWAY_PORT}"

        exec "${NODE_PATH}" "${MANAGEMENT_API}"
    ) >> ${LOG_FILE} 2>&1 &

    local main_pid=$!
    # 将后台进程的 PID 写入 PID 文件
    printf "%s" "${main_pid}" > ${PID_FILE}
    log_msg "Manager has been started, PID: ${main_pid}"

    # 等待端口就绪（而不是检查进程）
    log_msg "等待端口 ${MANAGEMENT_PORT} 就绪..."
    local ready=0
    for i in $(seq 1 10); do
        sleep 1
        if ss -ltn 2>/dev/null | grep -q ":${MANAGEMENT_PORT}\s"; then
            ready=1
            log_msg "✅ 端口 ${MANAGEMENT_PORT} 已就绪"
            break
        fi
        log_msg "等待中... (${i}/10)"
    done

    if [ $ready -eq 0 ]; then
        log_msg "⚠️  端口未就绪，但进程可能仍在启动中"

        # 检查进程是否还活着
        if ! check_process "${main_pid}"; then
            log_msg "❌ 进程已退出，启动失败"
            tail -20 "${LOG_FILE}"
            rm -f "${PID_FILE}"
            return 1
        fi

        log_msg "⚠️  进程正在运行但端口未就绪，可能需要更多时间"
    fi

    # # 等待 3 秒后检查进程是否存活
    # sleep 3
    # if ! check_process "${PID_FILE}"; then
    #     log_msg "❌ 进程启动失败"
    #     echo "Process failed to start, see log for details" > "${TRIM_TEMP_LOGFILE}"
    #     tail -10 "${LOG_FILE}" >> "${TRIM_TEMP_LOGFILE}"
    #     rm -f "${PID_FILE}"
    #     return 1
    # fi

    return 0
}

# 停止应用进程
# 先尝试发送 TERM 信号优雅关闭，等待最多 10 秒
# 如果进程仍未退出，则发送 KILL 信号强制终止
stop_process() {
    log_msg "Stopping process ..."
    # 检查 PID 文件是否存在且可读
    if [ -r "${PID_FILE}" ]; then
        # 读取 PID 并去除空白字符
        pid=$(head -n 1 "${PID_FILE}" | tr -d '[:space:]')

        log_msg "pid=${pid}"
        # 检查进程是否存在
        if ! check_process "${pid}"; then
            # 进程不存在，删除 PID 文件
            rm -f "${PID_FILE}"
            log_msg "process is not running, remove pid file 1"
            return
        fi

        # 发送 TERM 信号尝试优雅关闭
        log_msg "send TERM signal to PID:${pid}..."
        kill -TERM ${pid} >> ${LOG_FILE} 2>&1

        # 等待进程退出，最多等待 3 秒
        local count=0
        while check_process "${pid}" && [ $count -lt 3 ]; do
            sleep 1
            count=$((count + 1))
            log_msg "waiting process terminal... (${count}s/10s)"
        done

        # 如果进程仍在运行，发送 KILL 信号强制终止
        if check_process "${pid}"; then
            log_msg "send KILL signal to PID:${pid}..."
            kill -KILL "${pid}"
            sleep 1
            rm -f "${PID_FILE}"
        else
            log_msg "process killed... "
        fi
    fi

    # 兜底清理（第 179 行）
    pkill -f "management-api.js" 2>/dev/null || true
    pkill -f "node.*${MANAGEMENT_API}" 2>/dev/null || true

    # 强制清理端口占用
    local port_pids=$(lsof -ti:${MANAGEMENT_PORT} 2>/dev/null)
    if [ -n "${port_pids}" ]; then
        log_msg "发现端口 ${MANAGEMENT_PORT} 被占用，强制清理 PID: ${port_pids}"
        echo "${port_pids}" | xargs kill -9 2>/dev/null || true
    fi

    return 0
}

# 检查进程是否在运行
check_process() {
    local pid=$1
    if [ -z "${pid}" ]; then
        return 1
    fi
    if ps -p "${pid}" > /dev/null 2>&1; then
        return 0
    else
        return 1
    fi
}

# 检查应用状态
# 返回: 0 表示应用正在运行，3 表示应用未运行，1 表示出错

status() {
    if [ -f "${PID_FILE}" ]; then
        local pid
        pid=$(cat "${PID_FILE}" 2>/dev/null)
        if check_process "${pid}"; then
            log_msg "CHECKING: ${APP_NAME} 正在运行 (PID: ${pid})"
            return 0
        else
            log_msg "CHECKING: ERR ${APP_NAME} 进程已停止，但 PID 文件存在 (PID: ${pid})"
            rm -f "${PID_FILE}"
            return 3
        fi
    else
        log_msg "CHECKING: ${APP_NAME} 未运行"
        return 3
    fi
}

# 命令行参数处理
# 支持的命令: start, stop, status
case $1 in
start)
    # 启动命令：启动应用进程
    # 成功返回 0，失败返回 1
    start_process
    ;;
stop)
    # 停止命令：停止正在运行的应用
    # 成功返回 0，失败返回 1
    stop_process
    ;;
status)
    # 状态检查命令：检查应用是否正在运行
    # 运行中返回 0，未运行返回 3
    if status; then
        exit 0
    else
        exit 3
    fi
    ;;
restart)
    echo "Restarting process ..."
    stop_process
    sleep 2
    start_process
    ;;
*)
    # 未知命令，返回错误
    echo "使用方法: $0 {start|stop|restart|status}"
    exit 1
    ;;
esac
